 /*
+ * ecm_fib_event()
+ *	FIB event callback (Kernel 6.12+)
+ */
+static int ecm_fib_event(struct notifier_block *nb, unsigned long event, void *ptr)
+{
+	struct fib_notifier_info *info = (struct fib_notifier_info *)ptr;
+
+	switch (event) {
+	case FIB_EVENT_ENTRY_REPLACE:
+	case FIB_EVENT_ENTRY_DEL:
+	case FIB_EVENT_ENTRY_ADD:
+	case FIB_EVENT_RULE_ADD:
+	case FIB_EVENT_RULE_DEL:
+		if (info->family == AF_INET) {
+			DEBUG_TRACE("FIB IPv4 event %lu, flushing v4 connections\n", event);
+			ecm_db_connection_defunct_ip_version(4);
+		}
+#ifdef ECM_IPV6_ENABLE
+		else if (info->family == AF_INET6) {
+			DEBUG_TRACE("FIB IPv6 event %lu, flushing v6 connections\n", event);
+			ecm_db_connection_defunct_ip_version(6);
+		}
+#endif
+		break;
+	}
+
+	return NOTIFY_DONE;
+}
+
+static struct notifier_block ecm_fib_notifier = {
+	.notifier_call = ecm_fib_event,
+};
+
+
